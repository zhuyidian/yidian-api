{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode zstd gzip

	@blocked path /debug/* /metrics
	respond @blocked 404

	reverse_proxy new-api:3000 {
		# Flush streaming model responses immediately.
		flush_interval -1
		transport http {
			keepalive 90s
		}
	}

	log {
		output file /var/log/caddy/access.log {
			roll_size 100MiB
			roll_keep 10
			roll_keep_for 720h
		}
		format json
	}
}

