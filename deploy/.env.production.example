# Copy this file to deploy/.env.production on the server.
# Keep the real file private; it is ignored by Git.

# Public hostname. DNS must point to the Hong Kong server before Caddy starts.
DOMAIN=api.example.com
ACME_EMAIL=ops@example.com

# Keep every deployment immutable and rollback-friendly.
NEW_API_IMAGE=calciumion/new-api
NEW_API_VERSION=v1.0.0-rc.15

# Use URL-safe random values (hex is recommended). Never reuse these values.
POSTGRES_PASSWORD=replace_with_at_least_32_random_hex_characters
REDIS_PASSWORD=replace_with_at_least_32_random_hex_characters
SESSION_SECRET=replace_with_at_least_64_random_hex_characters
CRYPTO_SECRET=replace_with_at_least_64_random_hex_characters

TZ=Asia/Shanghai
NODE_NAME=hk-01
STREAMING_TIMEOUT=300
TRUSTED_REDIRECT_DOMAINS=api.example.com

# Explicit edge-facing safety limits. Durations are in seconds.
GLOBAL_API_RATE_LIMIT_ENABLE=true
GLOBAL_API_RATE_LIMIT=360
GLOBAL_API_RATE_LIMIT_DURATION=180
GLOBAL_WEB_RATE_LIMIT_ENABLE=true
GLOBAL_WEB_RATE_LIMIT=120
GLOBAL_WEB_RATE_LIMIT_DURATION=180
CRITICAL_RATE_LIMIT_ENABLE=true
CRITICAL_RATE_LIMIT=20
CRITICAL_RATE_LIMIT_DURATION=1200
MAX_REQUEST_BODY_MB=32
STREAM_SCANNER_MAX_BUFFER_MB=64
TLS_INSECURE_SKIP_VERIFY=false
